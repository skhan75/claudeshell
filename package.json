{
  "name": "claudeshell",
  "version": "0.1.0",
  "description": "A visual terminal shell for Claude Code — tabs, telemetry, pills, fast navigation",
  "license": "MIT",
  "author": "Sami Ahmad Khan",
  "repository": {
    "type": "git",
    "url": "https://github.com/skhan75/claudeshell"
  },
  "bugs": "https://github.com/skhan75/claudeshell/issues",
  "homepage": "https://github.com/skhan75/claudeshell#readme",
  "keywords": [
    "claude",
    "claude-code",
    "tui",
    "terminal",
    "ink",
    "ai"
  ],
  "type": "module",
  "bin": {
    "claudeshell": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc && chmod +x dist/cli.js",
    "dev": "tsx src/cli.tsx",
    "test": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.test.json",
    "prepublishOnly": "npm run typecheck && npm test && npm run build"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.176",
    "@xterm/headless": "^6.0.0",
    "ink": "^5.2.1",
    "react": "^18.3.1",
    "smol-toml": "^1.6.1",
    "zustand": "^5.0.14"
  },
  "optionalDependencies": {
    "node-pty": "^1.1.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "@types/react": "^18.3.31",
    "ink-testing-library": "^4.0.0",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "vitest": "^3.2.6"
  }
}
